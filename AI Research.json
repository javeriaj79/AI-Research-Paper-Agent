    {
      "parameters": {
        "jsCode": "const xml = $input.first().json.data;\n\n// Simple regex-based parser for arXiv Atom feed\nconst entries = xml.split('<entry>').slice(1);\n\nconst papers = entries.map(entry => {\n  const getTag = (tag) => {\n    const match = entry.match(new RegExp(`<${tag}>([\\\\s\\\\S]*?)<\\\\/${tag}>`));\n    return match ? match[1].trim().replace(/\\s+/g, ' ') : '';\n  };\n\n  const title = getTag('title');\n  const summary = getTag('summary');\n  const idMatch = entry.match(/<id>(.*?)<\\/id>/);\n  const link = idMatch ? idMatch[1].trim() : '';\n  const published = getTag('published');\n\n  // Extract authors\n  const authorMatches = [...entry.matchAll(/<name>(.*?)<\\/name>/g)];\n  const authors = authorMatches.map(m => m[1]).join(', ');\n\n  return {\n    title,\n    abstract: summary,\n    link,\n    published,\n    authors\n  };\n});\n\nreturn papers.map(paper => ({ json: paper }));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -720,
        16
      ],
      "id": "fecfbd62-8fb5-46fa-8a7a-0e22fa53007b",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=You are a research assistant helping an AI/ML graduate student track ONLY the most important, high-impact papers for PhD applications. Be a strict, selective reviewer — most papers should score low. Only genuinely novel, influential, or highly relevant work should score high.\n\nThis student's broad research interest covers: artificial intelligence, machine learning, deep learning, computer vision, biomedical AI, AI in healthcare, natural language processing (NLP), and retrieval-augmented generation (RAG) — treat all of these as ONE combined interest area, not separate categories.\n\nGiven this paper's title and abstract, do two things:\n1. Write a 2-line plain-English summary of what the paper does\n2. Give ONE single overall relevance score from 1 to 10 (a single integer, never a breakdown by topic) using this rubric:\n   - 1-3: Incremental, narrow, or unrelated to the student's interest area\n   - 4-6: Solid work but not groundbreaking or only loosely related\n   - 7-8: Strong, novel contribution directly relevant to the interest area\n   - 9-10: Exceptional, field-shifting work (rare)\n\nPaper title: {{ $json.title }}\nAbstract: {{ $json.abstract }}\n\nIMPORTANT: \"score\" must ALWAYS be a single plain integer, never an object or breakdown. Respond ONLY with valid JSON in this EXACT format, nothing else:\n{\"summary\": \"your summary here\", \"score\": 7}",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        -512,
        16
      ],
      "id": "79169f6b-393d-4e81-9fde-5eb6ce90196f",
      "name": "AI Agent"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst originalItems = $('Code in JavaScript').all();\n\nfunction extractScore(parsed) {\n  let s = parsed.score;\n  if (typeof s === 'object' && s !== null) {\n    const values = Object.values(s).filter(v => typeof v === 'number');\n    if (values.length > 0) {\n      s = values.reduce((a, b) => a + b, 0) / values.length; // average nikal lo\n    } else {\n      s = 0;\n    }\n  }\n  const num = Number(s);\n  return isNaN(num) ? 0 : num;\n}\n\nreturn items.map((item, index) => {\n  let rawText = item.json.output || item.json.text || '';\n  if (typeof rawText === 'object') {\n    rawText = JSON.stringify(rawText);\n  }\n  const jsonMatch = rawText.match(/\\{[\\s\\S]*\\}/);\n\n  let parsed;\n  try {\n    parsed = jsonMatch ? JSON.parse(jsonMatch[0]) : { summary: \"Parse failed\", score: 0 };\n  } catch (e) {\n    parsed = { summary: \"Parse failed\", score: 0 };\n  }\n\n  const original = originalItems[index] ? originalItems[index].json : {};\n\n  return {\n    json: {\n      title: original.title,\n      abstract: original.abstract,\n      link: original.link,\n      published: original.published,\n      authors: original.authors,\n      summary: typeof parsed.summary === 'object' ? JSON.stringify(parsed.summary) : parsed.summary,\n      score: extractScore(parsed)\n    }\n  };\n});"
      },
