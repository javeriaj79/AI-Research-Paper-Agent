    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst titles = data.title || [];\nconst summaries = data.summary || [];\nconst scores = data.score || [];\nconst links = data.link || [];\n\nlet digest = `Found ${titles.length} relevant paper(s) today:<br><br>`;\n\nfor (let i = 0; i < titles.length; i++) {\n  digest += `<b>Paper ${i + 1}: ${titles[i]}</b><br>`;\n  digest += `${summaries[i]}<br>`;\n  digest += `Score: ${scores[i]}/10<br>`;\n  digest += `Link: <a href=\"${links[i]}\">${links[i]}</a>`;\n  digest += `<br><br>———<br><br>`;\n}\n\nreturn [{ json: { digestText: digest, paperCount: titles.length } }];"
      },
